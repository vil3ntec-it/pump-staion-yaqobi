# این فایل را کپی کنید به نام  .env  و مقادیر را پر کنید.
# (فایل .env رمز دارد و نباید در گیت‌هاب گذاشته شود — در .gitignore هست.)

# پورتی که سرور روی آن گوش می‌دهد
PORT=8787

# رمز اشتراکی؛ همین رمز را در برنامه (localStorage: pumpServerToken) هم می‌گذارید.
# یک رشتهٔ تصادفی و طولانی بگذارید. خالی نگذارید وقتی سرور روی اینترنت است!
AUTH_TOKEN=یک-رمز-طولانی-و-تصادفی-اینجا

# آدرس اتصال به PostgreSQL
# قالب: postgresql://کاربر:رمز@localhost:5432/نام‌دیتابیس
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pump_yaqobi

# (اختیاری) فاصلهٔ ذخیره در دیتابیس بر حسب میلی‌ثانیه
PERSIST_DEBOUNCE_MS=400
