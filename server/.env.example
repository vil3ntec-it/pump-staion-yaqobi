# این فایل را کپی کن به نام  .env  و فقط دو خطِ اول را پر کن.
# (فایل .env رمز دارد و نباید در گیت‌هاب گذاشته شود — در .gitignore هست.)

# ۱) رمز اشتراکی بین سرور و برنامه. یک رشتهٔ دلخواه و طولانی بگذار.
#    همین رمز را بعداً در برنامه (فیلد «رمز سرور») هم می‌گذاری.
AUTH_TOKEN=یک-رمز-طولانی-دلخواه-مثلا-Mirza-Secret-92831

# ۲) رمز کاربر postgres که موقع نصب PostgreSQL گذاشتی.
DB_PASSWORD=رمزِ-postgres-که-موقع-نصب-گذاشتی

# --- بقیه معمولاً نیازی به تغییر ندارند ---

# پورت سروری که روی آن گوش می‌دهد
PORT=8787

# اگر PostgreSQL را با تنظیماتِ غیرپیش‌فرض نصب کردی، این‌ها را هم می‌توانی بدهی:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_NAME=pump_yaqobi

# (پیشرفته) به‌جای تکه‌های بالا می‌توانی کلِ آدرس را یک‌جا بدهی — این بر بقیه اولویت دارد:
# DATABASE_URL=postgresql://postgres:رمز@localhost:5432/pump_yaqobi
