# داده‌های کاربر و رمز — نباید در گیت‌هاب بروند
data/
.env
*.log
*.tmp

# نسخهٔ قابل‌حملِ Node که اسکریپت خودکار دانلود می‌کند (نباید در گیت‌هاب برود)
node-portable/

# node_modules را نادیده بگیر، ولی «ws» را نگه می‌داریم (vendored) تا نیازی به npm install نباشد
node_modules/*
!node_modules/ws
!node_modules/ws/**
