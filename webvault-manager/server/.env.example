# تنظیمات سرور WebVault Manager — این فایل را به .env کپی کنید (اختیاری)

# پورت سرور
WV_PORT=4600

# آدرس گوش‌دادن — 0.0.0.0 یعنی از کل شبکهٔ خانگی قابل دسترس است
WV_HOST=0.0.0.0

# مسیر ذخیرهٔ داده‌ها (پیش‌فرض: پوشهٔ data کنار برنامه)
# WV_DATA_DIR=/path/to/data

# محدودسازی CORS به یک دامنه/آدرس خاص (پیش‌فرض: * یعنی همه)
# WV_CORS=http://192.168.1.50:4600
